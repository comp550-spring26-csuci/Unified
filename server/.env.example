# Server
PORT=5001
MONGO_URI=mongodb://127.0.0.1:27017/unified_community_app
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173

# --- Password reset: real email (set ONE path: Resend OR SMTP) ---
#
# Option A — Resend (good for production once you verify a domain at resend.com):
#   RESEND_API_KEY=re_xxxx
#   EMAIL_FROM=Unified <onboarding@resend.dev>
#   Default onboarding@resend.dev often only delivers to your own inbox until you add a domain.
RESEND_API_KEY=

#
# Option B — Gmail (real mail to normal inboxes; use App Password, not your normal password):
#   1) Google Account → Security → 2-Step Verification ON
#   2) App passwords → create one for Mail → paste below (spaces in the password are OK)
#   3) Leave RESEND_API_KEY empty. Restart server — log should show: [mail] SMTP enabled: service=gmail
SMTP_SERVICE=gmail
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=Unified <youraddress@gmail.com>

#
# Option C — Custom SMTP host (Office365, SendGrid relay, etc.):
#   Leave SMTP_SERVICE empty and set host:
# SMTP_SERVICE=
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=

# Super admin seed
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=ChangeMe123!
SUPERADMIN_NAME=Super Admin
